{
  "name": "obsidian-pi-ide",
  "version": "0.1.0",
  "description": "Connect Obsidian to Pi Coding Agent via the pi-ide protocol.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "pi",
    "pi-ide",
    "coding-agent"
  ],
  "author": "Jenkins Chen",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/view": "^6.38.4",
    "@types/node": "^22.15.29",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.25.5",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
